' ══ LIST PAGE ══════════════════════════════════════════════════
' ════════════════════════════════════════════════════════════════

Sub BuildListPage
	pnlList.Initialize("pnlList")
	Activity.AddView(pnlList, 0, 0, 100%x, 100%y)
	pnlList.Color = Colors.RGB(245, 245, 245)

	' Toolbar
	Dim pnlTopBar As Panel
	pnlTopBar.Initialize("")
	pnlList.AddView(pnlTopBar, 0, 0, 100%x, 56dip)
	pnlTopBar.Color = Colors.RGB(33, 150, 243)

	lblListTitle.Initialize("")
	lblListTitle.Text = "PakuMedidas"
	lblListTitle.TextSize = 20
	lblListTitle.TextColor = Colors.White
	lblListTitle.Gravity = Gravity.CENTER_VERTICAL
	pnlTopBar.AddView(lblListTitle, 16dip, 0, 200dip, 56dip)

	btnNewProject.Initialize("btnNewProject")
	btnNewProject.Text = "+ Nueva"
	btnNewProject.TextSize = 14
	btnNewProject.Color = Colors.RGB(76, 175, 80)
	btnNewProject.TextColor = Colors.White
	pnlTopBar.AddView(btnNewProject, 100%x - 120dip, 8dip, 110dip, 40dip)

	' Lista scrollable
	svList.Initialize(56dip)
	pnlList.AddView(svList, 0, 56dip, 100%x, 100%y - 56dip)
	svListInner = svList.Panel
	svListInner.Color = Colors.RGB(245, 245, 245)
End Sub

Sub BuildTextInputPanel
	Dim panW As Int = 300dip
	Dim panH As Int = 160dip
	Dim cx As Int = (100%x - panW) / 2
	Dim cy As Int = (100%y - panH) / 2
	pnlTextInput.Initialize("")
	pnlTextInput.Color = Colors.RGB(40, 40, 40)
	pnlTextInput.Visible = False
	Activity.AddView(pnlTextInput, cx, cy, panW, panH)

	lblTextInputPrompt.Initialize("")
	lblTextInputPrompt.TextColor = Colors.White
	lblTextInputPrompt.TextSize = 14
	pnlTextInput.AddView(lblTextInputPrompt, 12dip, 12dip, panW - 24dip, 32dip)

	edTextInput.Initialize("edTextInput")
	edTextInput.SingleLine = True
	edTextInput.TextSize = 14
	edTextInput.TextColor = Colors.White
	pnlTextInput.AddView(edTextInput, 12dip, 52dip, panW - 24dip, 40dip)

	btnTextInputOK.Initialize("btnTextInputOK")
	btnTextInputOK.Text = "OK"
	btnTextInputOK.TextSize = 14
	pnlTextInput.AddView(btnTextInputOK, 12dip, 104dip, (panW - 36dip) / 2, 40dip)

	btnTextInputCancel.Initialize("btnTextInputCancel")
	btnTextInputCancel.Text = "Cancelar"
	btnTextInputCancel.TextSize = 12
	pnlTextInput.AddView(btnTextInputCancel, 24dip + (panW - 36dip) / 2, 104dip, (panW - 36dip) / 2, 40dip)
End Sub

Sub ShowTextInput(Prompt As String, Default As String, Action As String)
	mTextInputAction = Action
	lblTextInputPrompt.Text = Prompt
	edTextInput.Text = Default
	edTextInput.SelectAll
	pnlTextInput.BringToFront
	pnlTextInput.Visible = True
	edTextInput.RequestFocus
	' Forzar apertura del teclado
	Try
		Dim joET As JavaObject = edTextInput
		joET.RunMethod("requestFocus", Null)
		Dim ctx As JavaObject
		ctx.InitializeContext
		Dim imm As JavaObject = ctx.RunMethod("getSystemService", Array("input_method"))
		imm.RunMethod("showSoftInput", Array(joET, 1))
	Catch
	End Try
End Sub

Sub btnTextInputOK_Click
	pnlTextInput.Visible = False
	Dim txt As String = edTextInput.Text
	Dim newFontSize As Int
	If txt = "" Then Return
	Select mTextInputAction
		Case "rename_project"
			Starter.DB.ExecNonQuery2("UPDATE projects SET name = ?, modified_at = ? WHERE id = ?", _
				Array As String(txt, DateTime.Now, mTextInputProjectId))
			RefreshProjectList
		Case "new_cota"
			SaveUndoState
			CotaEngine.AddCota(mTextInputP1X, mTextInputP1Y, mTextInputP2X, mTextInputP2Y, txt, 0, -30, 25, Colors.RGB(255, 204, 0), 3, 14, 0)
			TouchMode = "none"
			RenderAll
		Case "edit_cota"
			SaveUndoState
			CotaEngine.SetCotaText(mTextInputElemIdx, txt)
			RenderAll
		Case "new_box"
			CotaEngine.SetTextBoxText(mTextInputElemIdx, txt)
			RenderAll
		Case "edit_box"
			SaveUndoState
			CotaEngine.SetTextBoxText(mTextInputElemIdx, txt)
			RenderAll
		Case "font_size_cota"
			If IsNumber(txt) Then newFontSize = txt
			If newFontSize >= 4 And newFontSize <= 200 Then
				SaveUndoState
				CotaEngine.SetCotaFontSize(mTextInputElemIdx, newFontSize)
				RenderAll
			End If
	End Select
	mTextInputAction = ""
End Sub

Sub btnTextInputCancel_Click
	pnlTextInput.Visible = False
	mTextInputAction = ""
	If mTextInputAction = "new_cota" Then TouchMode = "none"
End Sub

Sub ShowListPage
	CurrentPage = "main"
	pnlEditor.Visible = False
	pnlList.Visible = True
	RefreshProjectList
End Sub

Sub RefreshProjectList
	' Limpiar lista anterior
	For i = svListInner.NumberOfViews - 1 To 0 Step -1
		svListInner.RemoveViewAt(i)
	Next
	Dim itemH As Int = 96dip
	Dim yPos As Int = 0
	Dim rs As ResultSet = Starter.DB.ExecQuery("SELECT id, name, thumb_path, modified_at FROM projects ORDER BY modified_at DESC")
	Do While rs.NextRow
		Dim id As Int = rs.GetInt("id")
		Dim name As String = rs.GetString("name")
		Dim thumb As String = rs.GetString("thumb_path")
		Dim modAt As Long = rs.GetLong("modified_at")

		Dim pnl As Panel
		pnl.Initialize("pnlItem")
		Dim isSelected As Boolean = False
		pnl.Color = Colors.White
		pnl.Tag = id
		If MultiSelectMode Then
			isSelected = False
			For si = 0 To SelectedIds.Size - 1
				If SelectedIds.Get(si) = id Then
					isSelected = True
					Exit
				End If
			Next
			If isSelected Then pnl.Color = Colors.RGB(200, 230, 255)
		End If
		svListInner.AddView(pnl, 0, yPos, 100%x, itemH)

		' Divisor
		Dim div As Panel
		div.Initialize("")
		div.Color = Colors.RGB(220, 220, 220)
		svListInner.AddView(div, 0, yPos + itemH - 1, 100%x, 1)

		' Thumbnail
		If thumb <> "" And thumb <> Null And File.Exists(File.DirInternal, thumb) Then
			Dim iv As ImageView
			iv.Initialize("")
			iv.Bitmap = LoadBitmapResize(File.DirInternal, thumb, 80dip, 80dip, True)
			iv.Gravity = Gravity.FILL
			pnl.AddView(iv, 8dip, 8dip, 80dip, 80dip)
		End If

		Dim lbl As Label
		lbl.Initialize("")
		lbl.Text = name
		lbl.TextSize = 16
		lbl.TextColor = Colors.RGB(33, 33, 33)
		lbl.Gravity = Gravity.CENTER_VERTICAL
		pnl.AddView(lbl, 100dip, 8dip, 100%x - 160dip, 40dip)

		Dim lblDate As Label
		lblDate.Initialize("")
		DateTime.DateFormat = "dd/MM/yyyy HH:mm"
		lblDate.Text = DateTime.Date(modAt)
		lblDate.TextSize = 12
		lblDate.TextColor = Colors.Gray
		lblDate.Gravity = Gravity.CENTER_VERTICAL
		pnl.AddView(lblDate, 100dip, 48dip, 200dip, 30dip)

		yPos = yPos + itemH
	Loop
	rs.Close
	svList.Panel.Height = Max(yPos, 100%y - 56dip)
End Sub

Sub pnlItem_Click
	Dim v As Panel = Sender
	Dim projectId As Int
	projectId = v.Tag
	If MultiSelectMode Then
		ToggleSelection(projectId)
		Return
	End If
	OpenEditor(projectId)
End Sub

Sub pnlItem_LongClick
	Dim v As Panel = Sender
	Dim projectId As Int
	projectId = v.Tag
	Dim result As Int = InputList(Array("Abrir", "Renombrar", "Compartir PDF", "Seleccionar para compartir", "Eliminar"), "Proyecto", -1)
	Select result
		Case 0
			OpenEditor(projectId)
		Case 1
			mTextInputProjectId = projectId
			ShowTextInput("Nuevo nombre:", GetProjectName(projectId), "rename_project")
		Case 2
			ShareProjectPdf(projectId)
		Case 3
			EnterMultiSelectMode(projectId)
		Case 4
			Dim confirm As Int = Msgbox2("Eliminar este proyecto?", "Confirmar", "Eliminar", "", "Cancelar", Null)
			If confirm = DialogResponse.POSITIVE Then
				DeleteProject(projectId)
				RefreshProjectList
			End If
	End Select
End Sub

Sub btnNewProject_Click
	If MultiSelectMode Then
		ShareMultipleProjects
		Return
	End If
	CC.Show("image/*", "Selecciona una foto")
End Sub

Sub CC_Result(Success As Boolean, Dir As String, FileName As String)
	If Success = False Then Return

	' Cargar y redimensionar
	Dim bmp As Bitmap = LoadBitmap(Dir, FileName)
	If bmp.Width > 1920 Or bmp.Height > 1080 Then
		Dim ratio As Float = Min(1920.0 / bmp.Width, 1080.0 / bmp.Height)
		Dim newW As Int = bmp.Width * ratio
		Dim newH As Int = bmp.Height * ratio
		Dim resized As Bitmap
		resized.InitializeMutable(newW, newH)
		Dim cvs As Canvas
		cvs.Initialize2(resized)
		Dim srcRect As Rect : srcRect.Initialize(0, 0, bmp.Width, bmp.Height)
		Dim dstRect As Rect : dstRect.Initialize(0, 0, newW, newH)
		cvs.DrawBitmap(bmp, srcRect, dstRect)
		bmp = resized
	End If

	' Guardar imagen
	Dim imgName As String = "img_" & DateTime.Now & ".jpg"
	Dim out As OutputStream = File.OpenOutput(File.DirInternal, imgName, False)
	bmp.WriteToStream(out, 95, "JPEG")
	out.Close

	' Crear thumbnail
	Dim thumbName As String = "thumb_" & DateTime.Now & ".jpg"
	Dim thumbBmp As Bitmap = CreateScaledBitmap(bmp, 160, 160)
	Dim out2 As OutputStream = File.OpenOutput(File.DirInternal, thumbName, False)
	thumbBmp.WriteToStream(out2, 80, "JPEG")
	out2.Close

	' Nombre del proyecto desde nombre archivo
	Dim projName As String = GetContentDisplayName(Dir, FileName)
	If projName.Contains(".") Then projName = projName.SubString2(0, projName.LastIndexOf("."))
	If projName = "" Or projName.StartsWith("content") Then projName = "Proyecto " & DateTime.Date(DateTime.Now)
	If projName.Length > 30 Then projName = projName.SubString2(0, 30)

	' Insertar en DB
	Dim emptyJson As String = $"{"cotas":[],"textBoxes":[]}"$
	Starter.DB.ExecNonQuery2("INSERT INTO projects (name, image_path, thumb_path, annotations_json, created_at, modified_at) VALUES (?,?,?,?,?,?)", _
		Array As String(projName, imgName, thumbName, emptyJson, DateTime.Now, DateTime.Now))

	' Obtener ID del nuevo proyecto
	Dim rs As ResultSet = Starter.DB.ExecQuery("SELECT last_insert_rowid() AS id")
	rs.NextRow
	Dim newId As Int = rs.GetInt("id")
	rs.Close

	OpenEditor(newId)
End Sub

Sub CreateScaledBitmap(src As Bitmap, MaxW As Int, MaxH As Int) As Bitmap
	Dim ratio As Float = Min(MaxW / src.Width, MaxH / src.Height)
	Dim w As Int = Max(1, src.Width * ratio)
	Dim h As Int = Max(1, src.Height * ratio)
	Dim result As Bitmap
	result.InitializeMutable(w, h)
	Dim cvs As Canvas
	cvs.Initialize2(result)
	Dim srcR As Rect : srcR.Initialize(0, 0, src.Width, src.Height)
	Dim dstR As Rect : dstR.Initialize(0, 0, w, h)
	cvs.DrawBitmap(src, srcR, dstR)
	Return result
End Sub

Sub GetContentDisplayName(Dir As String, FileName As String) As String
	Try
		Dim uriStr As String
		If FileName.StartsWith("content://") Then
			uriStr = FileName
		Else If Dir.StartsWith("content://") Then
			uriStr = Dir
		Else
			Return FileName
		End If
		Dim joUri As JavaObject
		joUri.InitializeStatic("android.net.Uri")
		Dim uri As Object = joUri.RunMethod("parse", Array(uriStr))
		Dim context As JavaObject
		context.InitializeContext
		Dim cr As JavaObject = context.RunMethod("getContentResolver", Null)
		Dim cols(1) As String
		cols(0) = "_display_name"
		Dim cursor As JavaObject = cr.RunMethod("query", Array(uri, cols, Null, Null, Null))
		If cursor.IsInitialized Then
			If cursor.RunMethod("moveToFirst", Null) Then
				Dim name As String = cursor.RunMethod("getString", Array(0))
				cursor.RunMethod("close", Null)
				Return name
			End If
			cursor.RunMethod("close", Null)
		End If
	Catch
		Log("GetContentDisplayName error: " & LastException)
	End Try
	Return FileName
End Sub

Sub GetProjectName(id As Int) As String
	Dim rs As ResultSet = Starter.DB.ExecQuery2("SELECT name FROM projects WHERE id = ?", Array As String(id))
	If rs.NextRow Then
		Dim n As String = rs.GetString("name")
		rs.Close
		Return n
	End If
	rs.Close
	Return ""
End Sub

Sub DeleteProject(id As Int)
	Dim rs As ResultSet = Starter.DB.ExecQuery2("SELECT image_path, thumb_path FROM projects WHERE id = ?", Array As String(id))
	If rs.NextRow Then
		Dim img As String = rs.GetString("image_path")
		Dim thumb As String = rs.GetString("thumb_path")
		If img <> "" And File.Exists(File.DirInternal, img) Then File.Delete(File.DirInternal, img)
		If thumb <> "" And File.Exists(File.DirInternal, thumb) Then File.Delete(File.DirInternal, thumb)
	End If
	rs.Close
	Starter.DB.ExecNonQuery2("DELETE FROM projects WHERE id = ?", Array As String(id))
End Sub

' ── Multi-seleccion para compartir ──

Sub EnterMultiSelectMode(firstId As Int)
	MultiSelectMode = True
	SelectedIds.Initialize
	SelectedIds.Add(firstId)
	UpdateMultiSelectUI
	RefreshProjectList
End Sub

Sub ExitMultiSelectMode
	MultiSelectMode = False
	SelectedIds.Initialize
	UpdateMultiSelectUI
	RefreshProjectList
End Sub

Sub UpdateMultiSelectUI
	If MultiSelectMode Then
		lblListTitle.Text = "Seleccionar (" & SelectedIds.Size & ")"
		btnNewProject.Text = "Compartir (" & SelectedIds.Size & ")"
		btnNewProject.Color = Colors.RGB(33, 150, 243)
	Else
		lblListTitle.Text = "PakuMedidas"
		btnNewProject.Text = "+ Nueva"
		btnNewProject.Color = Colors.RGB(76, 175, 80)
	End If
End Sub

Sub ToggleSelection(id As Int)
	Dim found As Boolean = False
	For idx = 0 To SelectedIds.Size - 1
		If SelectedIds.Get(idx) = id Then
			SelectedIds.RemoveAt(idx)
			found = True
			Exit
		End If
	Next
	If found = False Then SelectedIds.Add(id)
	If SelectedIds.Size = 0 Then
		ExitMultiSelectMode
	Else
		UpdateMultiSelectUI
		RefreshProjectList
	End If
End Sub

Sub ShareMultipleProjects
	Dim sharedDir As String
	Dim uriList As JavaObject
	Dim projId As Int
	Dim rs As ResultSet
	Dim imgPath As String
	Dim jsonStr As String
	Dim bmp As Bitmap
	Dim fileName As String
	Dim filePath As String
	Dim shareUri As Object
	Dim listSize As Object
	Dim listSizeInt As Int
	Dim i As Intent
	Dim joIntent As JavaObject
	Dim jIntent As JavaObject
	Dim chooser As Object
	If SelectedIds.Size = 0 Then Return

	sharedDir = File.Combine(File.DirInternal, "shared")
	File.MakeDir(File.DirInternal, "shared")

	uriList.InitializeNewInstance("java.util.ArrayList", Null)

	For idx = 0 To SelectedIds.Size - 1
		projId = SelectedIds.Get(idx)
		rs = Starter.DB.ExecQuery2("SELECT image_path, annotations_json FROM projects WHERE id = ?", Array As String(projId))
		If rs.NextRow Then
			imgPath = rs.GetString("image_path")
			jsonStr = rs.GetString("annotations_json")
			rs.Close

			If File.Exists(File.DirInternal, imgPath) Then
				bmp = LoadBitmap(File.DirInternal, imgPath)
				CotaEngine.LoadFromJson(jsonStr)
				fileName = "PakuMedidas_" & projId & "_" & DateTime.Now & ".pdf"
				PdfExporter.ExportPdf(sharedDir, fileName, bmp, CotaEngine.GetCotas, CotaEngine.GetTextBoxes)

				filePath = File.Combine(sharedDir, fileName)
				shareUri = GetShareUri(filePath, fileName, "application/pdf")
				If shareUri <> Null Then
					uriList.RunMethod("add", Array(shareUri))
				End If
			End If
		Else
			rs.Close
		End If
	Next

	listSize = uriList.RunMethod("size", Null)
	listSizeInt = listSize
	If listSizeInt > 0 Then
		Try
			i.Initialize("android.intent.action.SEND_MULTIPLE", "")
			i.SetType("application/pdf")
			joIntent = i
			joIntent.RunMethod("putParcelableArrayListExtra", Array("android.intent.extra.STREAM", uriList))
			i.Flags = 1 ' FLAG_GRANT_READ_URI_PERMISSION
			jIntent.InitializeStatic("android.content.Intent")
			chooser = jIntent.RunMethod("createChooser", Array(i, "Enviar PDFs"))
			StartActivity(chooser)
		Catch
			Log("Error sharing multiple: " & LastException)
			ToastMessageShow("Error al compartir", True)
		End Try
	End If

	ExitMultiSelectMode
End Sub

Sub GetShareUri(FilePath As String, FileName As String, MimeType As String) As Object
	Dim build As JavaObject
	Dim sdk As Int
	Dim smBuilder As JavaObject
	Dim policy As Object
	Dim sm As JavaObject
	Dim joUri As JavaObject
	Dim f As JavaObject
	Try
		build.InitializeStatic("android.os.Build$VERSION")
		sdk = build.GetField("SDK_INT")

		If sdk >= 29 Then
			Return CopyToMediaStore(FilePath, FileName, MimeType)
		Else
			smBuilder.InitializeNewInstance("android.os.StrictMode$VmPolicy$Builder", Null)
			policy = smBuilder.RunMethod("build", Null)
			sm.InitializeStatic("android.os.StrictMode")
			sm.RunMethod("setVmPolicy", Array(policy))
			joUri.InitializeStatic("android.net.Uri")
			f.InitializeNewInstance("java.io.File", Array(FilePath))
			Return joUri.RunMethod("fromFile", Array(f))
		End If
	Catch
		Log("GetShareUri error: " & LastException)
		Return Null
	End Try
End Sub

