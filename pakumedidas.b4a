End Sub

Sub OpenEditor(ProjectId As Int)
	EditProjectId = ProjectId

	' Cargar datos del proyecto
	Dim rs As ResultSet = Starter.DB.ExecQuery2("SELECT * FROM projects WHERE id = ?", Array As String(ProjectId))
	If rs.NextRow = False Then
		rs.Close
		Return
	End If

	Dim imgPath As String = rs.GetString("image_path")
	Dim jsonStr As String = rs.GetString("annotations_json")
	Dim projName As String = rs.GetString("name")
	rs.Close

	lblEditorTitle.Text = projName

	' Cargar imagen
	If File.Exists(File.DirInternal, imgPath) Then
		OriginalBitmap = LoadBitmap(File.DirInternal, imgPath)
	Else
		ToastMessageShow("Imagen no encontrada", True)
		Return
	End If

	' Cargar anotaciones
	CotaEngine.LoadFromJson(jsonStr)

	' Reset view
	ZoomLevel = 1.0
	PanX = 0
	PanY = 0
	BaseScale = Min(pnlCanvas.Width / OriginalBitmap.Width, pnlCanvas.Height / OriginalBitmap.Height)

	' Reset state
	ActiveTool = "move"
	UpdateToolButtons
	TouchMode = "none"
	CotaP1X = -1
	SelectedType = ""
	SelectedIndex = -1
	UndoStack.Initialize
	RedoStack.Initialize

	' Init canvas
	xCanvas.Initialize(pnlCanvas)

	' Show editor
	CurrentPage = "editor"
	pnlList.Visible = False
	pnlEditor.Visible = True

	RenderAll
End Sub

' ── Tool buttons ──

Sub UpdateToolButtons
	Dim tools() As String = Array As String("move", "cota", "box", "delete")
	Dim btns() As Button = Array As Button(btnToolMove, btnToolCota, btnToolBox, btnToolDelete)
	For i = 0 To tools.Length - 1
		If tools(i) = ActiveTool Then
			btns(i).Color = Colors.RGB(33, 150, 243)
		Else
			btns(i).Color = Colors.RGB(80, 80, 80)
		End If
	Next
End Sub

Sub btnToolMove_Click
	ActiveTool = "move"
	SelectedType = ""
	SelectedIndex = -1
	CotaP1X = -1
	UpdateToolButtons
	RenderAll
End Sub

Sub btnToolCota_Click
	ActiveTool = "cota"
	CotaP1X = -1
	TouchMode = "none"
	SelectedType = ""
	SelectedIndex = -1
	UpdateToolButtons
	RenderAll
End Sub

Sub btnToolBox_Click
	ActiveTool = "box"
	SelectedType = ""
	SelectedIndex = -1
	CotaP1X = -1
	UpdateToolButtons
	RenderAll
End Sub

Sub btnToolDelete_Click
	ActiveTool = "delete"
	CotaP1X = -1
	UpdateToolButtons
	RenderAll
End Sub

Sub btnBack_Click
	SaveCurrentProject
	ShowListPage
End Sub

Sub btnUndo_Click
	If UndoStack.Size > 0 Then
		PushUndo(RedoStack)
		Dim json As String = UndoStack.Get(UndoStack.Size - 1)
		UndoStack.RemoveAt(UndoStack.Size - 1)
		CotaEngine.LoadFromJson(json)
		RenderAll
	End If
End Sub

Sub btnRedo_Click
	If RedoStack.Size > 0 Then
		PushUndo(UndoStack)
		Dim json As String = RedoStack.Get(RedoStack.Size - 1)
		RedoStack.RemoveAt(RedoStack.Size - 1)
		CotaEngine.LoadFromJson(json)
		RenderAll
	End If
End Sub

Sub PushUndo(stack As List)
	Dim json As String = CotaEngine.ToJson
	stack.Add(json)
	If stack.Size > 30 Then stack.RemoveAt(0)
End Sub

Sub SaveUndoState
	PushUndo(UndoStack)
	RedoStack.Initialize ' limpiar redo al hacer nueva accion
End Sub

' ── Save / Export / Share ──

Sub btnSave_Click
	If OriginalBitmap = Null Or OriginalBitmap.IsInitialized = False Then Return
	SaveCurrentProject

	' Render to full-res bitmap
	Dim outBmp As Bitmap
	outBmp.InitializeMutable(OriginalBitmap.Width, OriginalBitmap.Height)
	Dim cvs As Canvas
	cvs.Initialize2(outBmp)
	Dim r As Rect : r.Initialize(0, 0, OriginalBitmap.Width, OriginalBitmap.Height)
	cvs.DrawBitmap(OriginalBitmap, r, r)
	CotaEngine.RenderOnCanvas(cvs, 1.0, 0, 0, OriginalBitmap.Width, OriginalBitmap.Height)

	' Save to shared folder
	Dim sharedDir As String = File.Combine(File.DirInternal, "shared")
	File.MakeDir(File.DirInternal, "shared")
	Dim fileName As String = "PakuMedidas_" & DateTime.Now & ".jpg"
	Dim out As OutputStream = File.OpenOutput(sharedDir, fileName, False)
	outBmp.WriteToStream(out, 95, "JPEG")
	out.Close

	ToastMessageShow("JPG guardado: " & fileName, True)
End Sub

Sub btnPdf_Click
	If OriginalBitmap = Null Or OriginalBitmap.IsInitialized = False Then Return
	SaveCurrentProject

	Dim sharedDir As String = File.Combine(File.DirInternal, "shared")
	File.MakeDir(File.DirInternal, "shared")
	Dim fileName As String = "PakuMedidas_" & DateTime.Now & ".pdf"

	PdfExporter.ExportPdf(sharedDir, fileName, OriginalBitmap, CotaEngine.GetCotas, CotaEngine.GetTextBoxes)
	ToastMessageShow("PDF guardado: " & fileName, True)
End Sub

Sub btnShare_Click
	If OriginalBitmap = Null Or OriginalBitmap.IsInitialized = False Then Return
	SaveCurrentProject

	' Generar PDF primero
	Dim sharedDir As String = File.Combine(File.DirInternal, "shared")
	File.MakeDir(File.DirInternal, "shared")
	Dim fileName As String = "PakuMedidas_" & EditProjectId & ".pdf"
	PdfExporter.ExportPdf(sharedDir, fileName, OriginalBitmap, CotaEngine.GetCotas, CotaEngine.GetTextBoxes)

	' Compartir via intent
	ShareFile(sharedDir, fileName, "application/pdf")
End Sub

Sub ShareProjectPdf(projectId As Int)
	' Cargar datos, generar PDF y compartir
	Dim rs As ResultSet = Starter.DB.ExecQuery2("SELECT image_path, annotations_json FROM projects WHERE id = ?", Array As String(projectId))
	If rs.NextRow = False Then
		rs.Close
		Return
	End If
	Dim imgPath As String = rs.GetString("image_path")
	Dim jsonStr As String = rs.GetString("annotations_json")
	rs.Close

	If File.Exists(File.DirInternal, imgPath) = False Then
		ToastMessageShow("Imagen no encontrada", True)
		Return
	End If

	Dim bmp As Bitmap = LoadBitmap(File.DirInternal, imgPath)
	CotaEngine.LoadFromJson(jsonStr)

	Dim sharedDir As String = File.Combine(File.DirInternal, "shared")
	File.MakeDir(File.DirInternal, "shared")
	Dim fileName As String = "PakuMedidas_" & projectId & ".pdf"
	PdfExporter.ExportPdf(sharedDir, fileName, bmp, CotaEngine.GetCotas, CotaEngine.GetTextBoxes)

	ShareFile(sharedDir, fileName, "application/pdf")
End Sub

Sub ShareFile(Dir As String, FileName As String, MimeType As String)
	Try
		Dim filePath As String = File.Combine(Dir, FileName)

		Dim build As JavaObject
		build.InitializeStatic("android.os.Build$VERSION")
		Dim sdk As Int = build.GetField("SDK_INT")

		Dim shareUri As Object

		If sdk >= 29 Then
			' Android 10+: copiar a MediaStore.Downloads y compartir desde ahi
			shareUri = CopyToMediaStore(filePath, FileName, MimeType)
		Else
			' Android 7-9: deshabilitar StrictMode para permitir file:// URIs
			Dim smBuilder As JavaObject
			smBuilder.InitializeNewInstance("android.os.StrictMode$VmPolicy$Builder", Null)
			Dim policy As Object = smBuilder.RunMethod("build", Null)
			Dim sm As JavaObject
			sm.InitializeStatic("android.os.StrictMode")
			sm.RunMethod("setVmPolicy", Array(policy))
			Dim joUri As JavaObject
			joUri.InitializeStatic("android.net.Uri")
			Dim f As JavaObject
			f.InitializeNewInstance("java.io.File", Array(filePath))
			shareUri = joUri.RunMethod("fromFile", Array(f))
		End If

		If shareUri = Null Then
			ToastMessageShow("Error preparando archivo para compartir", True)
			Return
		End If

		Dim i As Intent
		i.Initialize(i.ACTION_SEND, "")
		i.SetType(MimeType)
		i.PutExtra("android.intent.extra.STREAM", shareUri)
		i.Flags = 1 ' FLAG_GRANT_READ_URI_PERMISSION
		Dim jIntent As JavaObject
		jIntent.InitializeStatic("android.content.Intent")
		Dim chooser As Object = jIntent.RunMethod("createChooser", Array(i, "Enviar"))
		StartActivity(chooser)
	Catch
		Log("Error sharing: " & LastException)
		ToastMessageShow("Error al compartir: " & LastException.Message, True)
	End Try
End Sub

Sub CopyToMediaStore(FilePath As String, FileName As String, MimeType As String) As Object
	Try
		Dim context As JavaObject
		context.InitializeContext
		Dim cr As JavaObject = context.RunMethod("getContentResolver", Null)

		Dim cv As JavaObject
		cv.InitializeNewInstance("android.content.ContentValues", Null)
		cv.RunMethod("put", Array("_display_name", FileName))
		cv.RunMethod("put", Array("mime_type", MimeType))

		Dim msDownloads As JavaObject
		msDownloads.InitializeStatic("android.provider.MediaStore$Downloads")
		Dim dlUri As Object = cr.RunMethod("insert", Array(msDownloads.GetField("EXTERNAL_CONTENT_URI"), cv))
		If dlUri = Null Then Return Null

		' Copiar bytes con loop manual (transferTo requiere API 33+)
		Dim fis As JavaObject
		fis.InitializeNewInstance("java.io.FileInputStream", Array(FilePath))
		Dim os As JavaObject = cr.RunMethod("openOutputStream", Array(dlUri))
		Dim buf(8192) As Byte
		Dim startOff As Int = 0
		Dim nObj As Object = fis.RunMethod("read", Array(buf))
		Dim n As Int = nObj
		Do While n > 0
			os.RunMethod("write", Array(buf, startOff, n))
			nObj = fis.RunMethod("read", Array(buf))
			n = nObj
		Loop
		fis.RunMethod("close", Null)
		os.RunMethod("flush", Null)
		os.RunMethod("close", Null)

		Return dlUri
	Catch
		Log("CopyToMediaStore error: " & LastException)
		Return Null
	End Try
End Sub

Sub SaveCurrentProject
	If EditProjectId < 0 Then Return
	Dim json As String = CotaEngine.ToJson
	Starter.DB.ExecNonQuery2("UPDATE projects SET annotations_json = ?, modified_at = ? WHERE id = ?", _
		Array As String(json, DateTime.Now, EditProjectId))
End Sub

Sub btnRotCW_Click
	If OriginalBitmap = Null Or OriginalBitmap.IsInitialized = False Then Return
	SaveUndoState
	RotateImage(90)
End Sub

Sub btnRotCCW_Click
	If OriginalBitmap = Null Or OriginalBitmap.IsInitialized = False Then Return
	SaveUndoState
	RotateImage(-90)
End Sub

Sub RotateImage(degrees As Int)
	Dim oldW As Int = OriginalBitmap.Width
	Dim oldH As Int = OriginalBitmap.Height
	Dim degreesF As Float = degrees
	Dim zeroI As Int = 0
	Dim matrix As JavaObject
	Dim joBmp As JavaObject
	Dim rotated As Bitmap

	matrix.InitializeNewInstance("android.graphics.Matrix", Null)
	matrix.RunMethod("postRotate", Array(degreesF))

	joBmp.InitializeStatic("android.graphics.Bitmap")
	rotated = joBmp.RunMethod("createBitmap", Array(OriginalBitmap, zeroI, zeroI, oldW, oldH, matrix, True))
	OriginalBitmap = rotated

	If degrees = 90 Or degrees = -270 Then
		CotaEngine.RotateAll90CW(oldW, oldH)
	Else If degrees = -90 Or degrees = 270 Then
		CotaEngine.RotateAll90CCW(oldW, oldH)
	End If

	BaseScale = Min(pnlCanvas.Width / OriginalBitmap.Width, pnlCanvas.Height / OriginalBitmap.Height)
	SelectedType = ""
	SelectedIndex = -1
	PanX = 0
	PanY = 0

	SaveRotatedImage
	RenderAll
End Sub

Sub SaveRotatedImage
	Dim rs As ResultSet
	Dim imgPath As String
	Dim out As OutputStream
	Dim rs2 As ResultSet
	Dim thumbPath As String
	Dim thumbBmp As Bitmap
	Dim out2 As OutputStream
	If EditProjectId < 0 Then Return
	rs = Starter.DB.ExecQuery2("SELECT image_path FROM projects WHERE id = ?", Array As String(EditProjectId))
	If rs.NextRow Then
		imgPath = rs.GetString("image_path")
	End If
	rs.Close
	If imgPath <> "" Then
		out = File.OpenOutput(File.DirInternal, imgPath, False)
		OriginalBitmap.WriteToStream(out, 95, "JPEG")
		out.Close
		rs2 = Starter.DB.ExecQuery2("SELECT thumb_path FROM projects WHERE id = ?", Array As String(EditProjectId))
		If rs2.NextRow Then thumbPath = rs2.GetString("thumb_path")
		rs2.Close
		If thumbPath <> "" Then
			thumbBmp = CreateScaledBitmap(OriginalBitmap, 160, 160)
			out2 = File.OpenOutput(File.DirInternal, thumbPath, False)
			thumbBmp.WriteToStream(out2, 80, "JPEG")
			out2.Close
		End If
	End If
End Sub

' ════════════════════════════════════════════════════════════════
' ══ CANVAS RENDERING ═══════════════════════════════════════════
' ════════════════════════════════════════════════════════════════

Sub RenderAll
	If OriginalBitmap = Null Or OriginalBitmap.IsInitialized = False Then Return

	Dim bc As B4XCanvas = xCanvas
	bc.ClearRect(bc.TargetRect)

	' Dibujar imagen
	Dim s As Float = BaseScale * ZoomLevel
	Dim imgW As Float = OriginalBitmap.Width * s
	Dim imgH As Float = OriginalBitmap.Height * s
	Dim ox As Float = (pnlCanvas.Width - imgW) / 2 + PanX
	Dim oy As Float = (pnlCanvas.Height - imgH) / 2 + PanY

	Dim dstRect As B4XRect
	dstRect.Initialize(ox, oy, ox + imgW, oy + imgH)
	bc.DrawBitmap(OriginalBitmap, dstRect)

	' Dibujar anotaciones
	CotaEngine.RenderOnB4XCanvas(bc, s, ox, oy, SelectedType, SelectedIndex)

	' Dibujar punto P1 si estamos colocando cota
	If CotaP1X >= 0 Then
		Dim sx As Float = CotaP1X * s + ox
		Dim sy As Float = CotaP1Y * s + oy
		bc.DrawCircle(sx, sy, 6dip, xui.Color_Red, True, 0)
		bc.DrawCircle(sx, sy, 8dip, xui.Color_White, False, 2dip)
	End If

	bc.Invalidate
End Sub

' Conversiones coordenadas
Sub ImgToScreen(ix As Float, iy As Float) As Float()
	Dim s As Float = BaseScale * ZoomLevel
	Dim ox As Float = (pnlCanvas.Width - OriginalBitmap.Width * s) / 2 + PanX
	Dim oy As Float = (pnlCanvas.Height - OriginalBitmap.Height * s) / 2 + PanY
	Return Array As Float(ix * s + ox, iy * s + oy)
End Sub

Sub ScreenToImg(sx As Float, sy As Float) As Float()
	Dim s As Float = BaseScale * ZoomLevel
	Dim ox As Float = (pnlCanvas.Width - OriginalBitmap.Width * s) / 2 + PanX
	Dim oy As Float = (pnlCanvas.Height - OriginalBitmap.Height * s) / 2 + PanY
	Return Array As Float((sx - ox) / s, (sy - oy) / s)
End Sub

' ════════════════════════════════════════════════════════════════
' ══ TOUCH HANDLING ═════════════════════════════════════════════
' ════════════════════════════════════════════════════════════════

Sub Canvas_Touch(View As Object, PointerID As Int, Action As Int, X As Float, Y As Float)
	Dim pointerCount As Int = GS.GetPointerCount
	Dim maskedAction As Int = Bit.And(Action, 255) ' ACTION_MASK = 0xFF

	Select maskedAction
		Case 0 ' ACTION_DOWN
			HandleTouchDown(X, Y, pointerCount)
		Case 5 ' ACTION_POINTER_DOWN (segundo dedo)
			HandlePointerDown(X, Y, pointerCount)
		Case 2 ' ACTION_MOVE
			HandleTouchMove(X, Y, pointerCount)
		Case 6 ' ACTION_POINTER_UP (segundo dedo levanta)
			HandlePointerUp(X, Y, pointerCount)
		Case 1, 3 ' ACTION_UP, ACTION_CANCEL
			HandleTouchUp(X, Y)
	End Select
End Sub

Sub HandlePointerDown(X As Float, Y As Float, PointerCount As Int)
	Dim p0x As Float
	Dim p0y As Float
	Dim p1x As Float
	Dim p1y As Float
	If PointerCount >= 2 Then
		PreviousTouchMode = TouchMode
		p0x = GS.GetX(0) : p0y = GS.GetY(0)
		p1x = GS.GetX(1) : p1y = GS.GetY(1)
		PinchStartDist = Sqrt(Power(p0x - p1x, 2) + Power(p0y - p1y, 2))
		PinchStartZoom = ZoomLevel
		TouchMode = "pinch"
		HideMagnifier
	End If
End Sub

Sub HandlePointerUp(X As Float, Y As Float, PointerCount As Int)
	If TouchMode = "pinch" Then
		TouchMode = "none"
		LastTouchX = X
		LastTouchY = Y
		RenderAll
	End If
End Sub

Sub HandleTouchDown(X As Float, Y As Float, PointerCount As Int)
	Dim p0x As Float
	Dim p0y As Float
	Dim p1x As Float
	Dim p1y As Float
	TouchStartX = X
	TouchStartY = Y
	LastTouchX = X
	LastTouchY = Y
	mTouchMoved = False

	If PointerCount >= 2 Then
		' Pinch zoom
		PreviousTouchMode = TouchMode
		p0x = GS.GetX(0) : p0y = GS.GetY(0)
		p1x = GS.GetX(1) : p1y = GS.GetY(1)
		PinchStartDist = Sqrt(Power(p0x - p1x, 2) + Power(p0y - p1y, 2))
		PinchStartZoom = ZoomLevel
		TouchMode = "pinch"
		HideMagnifier
		Return
	End If

	Dim imgPt() As Float = ScreenToImg(X, Y)
	Dim ix As Float = imgPt(0)
	Dim iy As Float = imgPt(1)

	Select ActiveTool
		Case "move"
			' Hit test para elementos
			Dim hit As Map = CotaEngine.HitTest(ix, iy, 30 / (BaseScale * ZoomLevel))
			If hit.Get("type") <> "" Then
				SelectedType = hit.Get("type")
				SelectedIndex = hit.Get("index")
				DragPartIndex = hit.Get("part")
				TouchMode = "drag_" & hit.Get("dragMode")
				SaveUndoState
				RenderAll
			Else
				SelectedType = ""
				SelectedIndex = -1
				TouchMode = "pan"
				RenderAll
			End If

		Case "cota"
			If CotaP1X < 0 Then
				' Primer punto
				CotaP1X = ix
				CotaP1Y = iy
				TouchMode = "place_cota1"
				ShowMagnifier(X, Y, ix, iy)
			Else
				' Segundo punto
				TouchMode = "place_cota2"
				ShowMagnifier(X, Y, ix, iy)
			End If

		Case "box"
			SaveUndoState
			Dim boxW As Float = 200
			Dim boxH As Float = 60
			Dim tlx As Float = ix - boxW/2 : Dim tly As Float = iy - boxH/2
			Dim brx As Float = ix + boxW/2 : Dim bry As Float = iy + boxH/2
			Dim semiWhite As Int = Colors.ARGB(180, 255, 255, 255)
			CotaEngine.AddTextBox(tlx, tly, brx, tly, brx, bry, tlx, bry, "Texto", semiWhite, Colors.Black, Colors.Black, 14)
			SelectedType = "box"
			SelectedIndex = CotaEngine.GetTextBoxes.Size - 1
			ActiveTool = "move"
			UpdateToolButtons
			RenderAll
			' Pedir texto inmediatamente
			mTextInputElemIdx = SelectedIndex
			ShowTextInput("Texto:", "Texto", "new_box")

		Case "delete"
			Dim hit As Map = CotaEngine.HitTest(ix, iy, 30 / (BaseScale * ZoomLevel))
			If hit.Get("type") <> "" Then
				SaveUndoState
				CotaEngine.DeleteElement(hit.Get("type"), hit.Get("index"))
				SelectedType = ""
				SelectedIndex = -1
				RenderAll
			End If
	End Select
End Sub

Sub HandleTouchMove(X As Float, Y As Float, PointerCount As Int)
	Dim p0x As Float
	Dim p0y As Float
	Dim p1x As Float
	Dim p1y As Float
	Dim dist As Float
	' Pinch zoom: si hay 2+ dedos, entrar en pinch siempre
	If PointerCount >= 2 And TouchMode <> "pinch" Then
		PreviousTouchMode = TouchMode
		p0x = GS.GetX(0) : p0y = GS.GetY(0)
		p1x = GS.GetX(1) : p1y = GS.GetY(1)
		PinchStartDist = Sqrt(Power(p0x - p1x, 2) + Power(p0y - p1y, 2))
		PinchStartZoom = ZoomLevel
		TouchMode = "pinch"
		HideMagnifier
	End If
	If TouchMode = "pinch" And PointerCount >= 2 Then
		p0x = GS.GetX(0) : p0y = GS.GetY(0)
		p1x = GS.GetX(1) : p1y = GS.GetY(1)
		dist = Sqrt(Power(p0x - p1x, 2) + Power(p0y - p1y, 2))
		If PinchStartDist > 10 Then
			ZoomLevel = PinchStartZoom * (dist / PinchStartDist)
			ZoomLevel = Max(0.2, Min(ZoomLevel, 10.0))
			RenderAll
		End If
		Return
	End If
	' Si estabamos en pinch pero queda 1 dedo, salir de pinch
	If TouchMode = "pinch" Then
		TouchMode = "none"
		LastTouchX = X
		LastTouchY = Y
		Return
	End If

	Dim moveDist As Float = Sqrt(Power(X - TouchStartX, 2) + Power(Y - TouchStartY, 2))
	If moveDist > 12dip Then mTouchMoved = True
	Dim dx As Float = X - LastTouchX
	Dim dy As Float = Y - LastTouchY
	LastTouchX = X
	LastTouchY = Y

	Select TouchMode
		Case "pan"
			PanX = PanX + dx
			PanY = PanY + dy
			RenderAll

		Case "place_cota1"
			Dim imgPt() As Float = ScreenToImg(X, Y)
			CotaP1X = imgPt(0)
			CotaP1Y = imgPt(1)
			ShowMagnifier(X, Y, CotaP1X, CotaP1Y)
			RenderAll

		Case "place_cota2"
			Dim imgPt() As Float = ScreenToImg(X, Y)
			ShowMagnifier(X, Y, imgPt(0), imgPt(1))
			RenderAll

		Case "drag_endpoint"
			Dim imgPt() As Float = ScreenToImg(X, Y)
			ShowMagnifier(X, Y, imgPt(0), imgPt(1))
			CotaEngine.MoveCotaEndpoint(SelectedIndex, DragPartIndex, imgPt(0), imgPt(1))
			RenderAll

		Case "drag_text"
			Dim s As Float = BaseScale * ZoomLevel
			CotaEngine.MoveCotaText(SelectedIndex, dx / s, dy / s)
			RenderAll

		Case "drag_offset"
			Dim s As Float = BaseScale * ZoomLevel
			CotaEngine.MoveCotaOffset(SelectedIndex, dx / s, dy / s)
			RenderAll

		Case "drag_box"
			Dim s As Float = BaseScale * ZoomLevel
			CotaEngine.MoveTextBox(SelectedIndex, dx / s, dy / s)
			RenderAll

		Case "drag_boxhandle"
			Dim imgPt() As Float = ScreenToImg(X, Y)
			ShowMagnifier(X, Y, imgPt(0), imgPt(1))
			CotaEngine.MoveBoxCorner(SelectedIndex, DragPartIndex, imgPt(0), imgPt(1))
			RenderAll
	End Select
End Sub

Sub HandleTouchUp(X As Float, Y As Float)
	HideMagnifier

	If TouchMode = "pinch" Then
		TouchMode = "none"
		RenderAll
		Return
	End If

	Select TouchMode
		Case "place_cota1"
			Dim imgPt() As Float = ScreenToImg(X, Y)
			CotaP1X = imgPt(0)
			CotaP1Y = imgPt(1)
			RenderAll
			' Esperar segundo punto

		Case "place_cota2"
			Dim imgPt() As Float = ScreenToImg(X, Y)
			Dim p2x As Float = imgPt(0)
			Dim p2y As Float = imgPt(1)

			' Guardar ambos puntos antes de resetear P1
			mTextInputP1X = CotaP1X
			mTextInputP1Y = CotaP1Y
			mTextInputP2X = p2x
			mTextInputP2Y = p2y
			CotaP1X = -1
			ShowTextInput("Medida:", "", "new_cota")
			RenderAll
	End Select

	TouchMode = "none"
End Sub

' ── Long press en editor (para menu contextual) ──
Sub pnlCanvas_LongClick
	If ActiveTool <> "move" Then Return
	If mTouchMoved Then Return
	If SelectedType = "" Or SelectedIndex < 0 Then Return

	If SelectedType = "cota" Then
		Dim result As Int = InputList(Array("Editar texto", "Cambiar color", "Rotar texto " & Chr(0x2192), "Rotar texto " & Chr(0x2190), "Tamano texto", "Duplicar", "Eliminar"), "Cota", -1)
		Dim curAngle As Int
		Select result
			Case 0 ' Editar texto
				mTextInputElemIdx = SelectedIndex
				ShowTextInput("Medida:", CotaEngine.GetCotaText(SelectedIndex), "edit_cota")
			Case 1 ' Color
				ShowColorPicker("cota", SelectedIndex)
			Case 2 ' Rotar texto derecha (+90)
				SaveUndoState
				curAngle = CotaEngine.GetCotaTextAngle(SelectedIndex)
				curAngle = curAngle + 90
				If curAngle >= 360 Then curAngle = curAngle - 360
				CotaEngine.SetCotaTextAngle(SelectedIndex, curAngle)
				RenderAll
			Case 3 ' Rotar texto izquierda (-90)
				SaveUndoState
				curAngle = CotaEngine.GetCotaTextAngle(SelectedIndex)
				curAngle = curAngle - 90
				If curAngle < 0 Then curAngle = curAngle + 360
				CotaEngine.SetCotaTextAngle(SelectedIndex, curAngle)
				RenderAll
			Case 4 ' Tamano texto
				ShowFontSizePicker(SelectedIndex)
			Case 5 ' Duplicar
				SaveUndoState
				CotaEngine.DuplicateCota(SelectedIndex)
				RenderAll
			Case 6 ' Eliminar
				SaveUndoState
				CotaEngine.DeleteElement("cota", SelectedIndex)
				SelectedType = ""
				SelectedIndex = -1
				RenderAll
		End Select

	Else If SelectedType = "box" Then
		Dim result As Int = InputList(Array("Editar texto", "Color fondo", "Color texto", "Color borde", "Duplicar", "Eliminar"), "Caja de texto", -1)
		Select result
			Case 0 ' Editar texto
				mTextInputElemIdx = SelectedIndex
				ShowTextInput("Texto:", CotaEngine.GetTextBoxText(SelectedIndex), "edit_box")
			Case 1 ' Color fondo
				ShowColorPicker("box_bg", SelectedIndex)
			Case 2 ' Color texto
				ShowColorPicker("box_text", SelectedIndex)
			Case 3 ' Color borde
				ShowColorPicker("box_border", SelectedIndex)
			Case 4 ' Duplicar
				SaveUndoState
				CotaEngine.DuplicateTextBox(SelectedIndex)
				RenderAll
			Case 5 ' Eliminar
				SaveUndoState
				CotaEngine.DeleteElement("box", SelectedIndex)
				SelectedType = ""
				SelectedIndex = -1
				RenderAll
		End Select
	End If
End Sub

Sub ShowColorPicker(Target As String, Index As Int)
	Dim colorNames() As String = Array As String("Amarillo", "Rojo", "Azul", "Verde", "Blanco", "Negro", "Naranja", "Magenta")
	Dim colorValues() As Int = Array As Int( _
		Colors.RGB(255, 204, 0), Colors.RGB(255, 50, 50), Colors.RGB(50, 150, 255), Colors.RGB(50, 200, 50), _
		Colors.White, Colors.Black, Colors.RGB(255, 150, 0), Colors.RGB(255, 0, 255))

	Dim result As Int = InputList(colorNames, "Elige color", -1)
	If result >= 0 Then
		SaveUndoState
		Dim c As Int = colorValues(result)
		Select Target
			Case "cota"
				CotaEngine.SetCotaColor(Index, c)
			Case "box_bg"
				CotaEngine.SetTextBoxBgColor(Index, c)
			Case "box_text"
				CotaEngine.SetTextBoxTextColor(Index, c)
			Case "box_border"
				CotaEngine.SetTextBoxBorderColor(Index, c)
		End Select
		RenderAll
	End If
End Sub

Sub ShowFontSizePicker(cotaIdx As Int)
	mTextInputElemIdx = cotaIdx
	Dim curSize As Int = CotaEngine.GetCotaFontSize(cotaIdx)
	ShowTextInput("Tamano de texto:", curSize, "font_size_cota")
End Sub


' ════════════════════════════════════════════════════════════════
' ══ MAGNIFIER ══════════════════════════════════════════════════
' ════════════════════════════════════════════════════════════════

Sub ShowMagnifier(screenX As Float, screenY As Float, imgX As Float, imgY As Float)
	If OriginalBitmap = Null Or OriginalBitmap.IsInitialized = False Then Return

	MagnifierVisible = True
	pnlMagnifier.Visible = True

	' Posicionar: arriba-izquierda del dedo, si no cabe, mover
	Dim magSize As Int = 120dip
	Dim mx As Int = screenX - magSize - 30dip
	Dim my As Int = screenY - magSize - 30dip
	If mx < 0 Then mx = screenX + 30dip
	If my < 0 Then my = screenY + 30dip
	' Adjust for pnlCanvas offset
	my = my + 48dip ' top bar height
	pnlMagnifier.Left = mx
	pnlMagnifier.Top = my

	' Crop region (30px radius around point in image space)
	Dim radius As Int = 30
	Dim cx As Int = Max(radius, Min(imgX, OriginalBitmap.Width - radius))
	Dim cy As Int = Max(radius, Min(imgY, OriginalBitmap.Height - radius))

	Dim cropSize As Int = radius * 2
	Dim cropBmp As Bitmap
	cropBmp.InitializeMutable(cropSize, cropSize)
	Dim cvs As Canvas
	cvs.Initialize2(cropBmp)
	Dim srcR As Rect : srcR.Initialize(cx - radius, cy - radius, cx + radius, cy + radius)
	Dim dstR As Rect : dstR.Initialize(0, 0, cropSize, cropSize)
	cvs.DrawBitmap(OriginalBitmap, srcR, dstR)

	' Scale up to magnifier size and draw crosshair
	Dim magPx As Int = 116dip
	Dim magBmp As Bitmap
	magBmp.InitializeMutable(magPx, magPx)
	Dim cvs2 As Canvas
	cvs2.Initialize2(magBmp)
	Dim srcR2 As Rect : srcR2.Initialize(0, 0, cropSize, cropSize)
	Dim dstR2 As Rect : dstR2.Initialize(0, 0, magPx, magPx)
	cvs2.DrawBitmap(cropBmp, srcR2, dstR2)

	' Crosshair
	Dim mid As Int = magPx / 2
	Dim paint As Object ' Use direct canvas methods
	cvs2.DrawLine(mid, 0, mid, magPx, Colors.Red, 1dip)
	cvs2.DrawLine(0, mid, magPx, mid, Colors.Red, 1dip)

	imgMagnifier.Bitmap = magBmp
End Sub

Sub HideMagnifier
	MagnifierVisible = False
	pnlMagnifier.Visible = False
End Sub
