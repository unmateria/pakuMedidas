#Region Project Attributes
	#ApplicationLabel: PakuMedidas
	#VersionCode: 1
	#VersionName: 1.0
	#SupportedOrientations: unspecified
	#CanInstallToExternalStorage: False
#End Region

#Region Activity Attributes
	#FullScreen: False
	#IncludeTitle: False
#End Region

Sub Process_Globals
	Public xui As XUI
	Dim CC As ContentChooser
End Sub

Sub Globals
	' ── Paneles principales ──
	Private pnlList As Panel
	Private pnlEditor As Panel
	Private CurrentPage As String

	' ── Lista de proyectos ──
	Private svList As ScrollView
	Private svListInner As Panel
	Private lblListTitle As Label
	Private btnNewProject As Button
	Private MultiSelectMode As Boolean = False
	Private SelectedIds As List

	' ── Editor ──
	Private pnlCanvas As Panel
	Private pnlToolbar As Panel
	Private pnlMagnifier As Panel
	Private xCanvas As B4XCanvas
	Private imgMagnifier As ImageView

	' Estado editor
	Private EditProjectId As Int = -1
	Private OriginalBitmap As Bitmap
	Private ZoomLevel As Float = 1.0
	Private PanX As Float = 0
	Private PanY As Float = 0
	Private BaseScale As Float = 1.0

	' Touch
	Private GS As Gestures
	Private TouchMode As String = "none" ' none, pan, pinch, place_cota1, place_cota2, drag_endpoint, drag_text, drag_offset, place_box, drag_box, drag_boxhandle
	Private TouchStartX As Float
	Private TouchStartY As Float
	Private LastTouchX As Float
	Private LastTouchY As Float
	Private PinchStartDist As Float
	Private PinchStartZoom As Float
	Private PreviousTouchMode As String = "none"

	' Herramienta activa
	Private ActiveTool As String = "move" ' move, cota, box, delete
	Private btnToolCota As Button
	Private btnToolBox As Button
	Private btnToolMove As Button
	Private btnToolDelete As Button
	Private btnUndo As Button
	Private btnRedo As Button
	Private btnSave As Button
	Private btnPdf As Button
	Private btnShare As Button
	Private btnBack As Button
	Private btnRotCW As Button
	Private btnRotCCW As Button
	Private lblEditorTitle As Label

	' Cota en progreso
	Private CotaP1X As Float = -1
	Private CotaP1Y As Float = -1

	' Elemento seleccionado
	Private SelectedType As String = "" ' "cota" o "box"
	Private SelectedIndex As Int = -1
	Private DragPartIndex As Int = -1 ' para endpoints: 0=p1, 1=p2; para box handles: 0-3

	' Magnifier
	Private MagnifierVisible As Boolean = False
	Private mTouchMoved As Boolean = False

	' Undo/Redo
	Private UndoStack As List
	Private RedoStack As List

	' TextInput overlay
	Private pnlTextInput As Panel
	Private lblTextInputPrompt As Label
	Private edTextInput As EditText
	Private btnTextInputOK As Button
	Private btnTextInputCancel As Button
	Private mTextInputAction As String   ' "rename_project","new_cota","edit_cota","new_box","edit_box"
	Private mTextInputProjectId As Int
	Private mTextInputElemIdx As Int
	Private mTextInputP1X As Float
	Private mTextInputP1Y As Float
	Private mTextInputP2X As Float
	Private mTextInputP2Y As Float
End Sub

Sub Activity_Create(FirstTime As Boolean)
	If FirstTime Then
		CC.Initialize("CC")
		SelectedIds.Initialize
		UndoStack.Initialize
		RedoStack.Initialize
	End If
	BuildListPage
	BuildEditorPage
	BuildTextInputPanel
	ShowListPage
End Sub

Sub Activity_Resume
End Sub

Sub Activity_Pause(UserClosed As Boolean)
	If EditProjectId >= 0 Then
		SaveCurrentProject
	End If
End Sub

Sub Activity_KeyPress(KeyCode As Int) As Boolean
	If KeyCode = KeyCodes.KEYCODE_BACK Then
		If MultiSelectMode Then
			ExitMultiSelectMode
			Return True
		End If
		If CurrentPage = "editor" Then
			SaveCurrentProject
			ShowListPage
			Return True
		End If
	End If
	Return False
End Sub

