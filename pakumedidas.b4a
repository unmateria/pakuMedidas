Sub BuildEditorPage
	pnlEditor.Initialize("pnlEditor")
	Activity.AddView(pnlEditor, 0, 0, 100%x, 100%y)
	pnlEditor.Color = Colors.RGB(30, 30, 30)

	' ── Top toolbar ──
	Dim topH As Int = 48dip
	Dim pnlTop As Panel
	pnlTop.Initialize("")
	pnlEditor.AddView(pnlTop, 0, 0, 100%x, topH)
	pnlTop.Color = Colors.RGB(50, 50, 50)

	btnBack.Initialize("btnBack")
	btnBack.Text = Chr(0x2190) ' ←
	btnBack.TextSize = 22
	btnBack.Color = Colors.Transparent
	btnBack.TextColor = Colors.White
	pnlTop.AddView(btnBack, 0, 0, 48dip, topH)

	lblEditorTitle.Initialize("")
	lblEditorTitle.TextSize = 14
	lblEditorTitle.TextColor = Colors.White
	lblEditorTitle.Gravity = Gravity.CENTER_VERTICAL
